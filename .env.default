# Nexus AI — default configuration template
# This file IS tracked by git. It provides config structure + safe defaults.
# To set your own API keys, create a .env file (gitignored) alongside this,
# or run: python setup_keys.py
#
# The interface will auto-prompt for missing keys on first launch.

# LLM — powers Nexus's brain (required for AI responses)
ANTHROPIC_API_KEY=

# ElevenLabs TTS — premium voice (optional, Edge TTS is free default)
ELEVENLABS_API_KEY=
